                  ]
                },
                "accordion_row_3g8GFq": {
                  "type": "_accordion-row",
                  "name": "t:names.accordion_row",
                  "settings": {
                    "heading": "Warum muss ich die Freiexemplare gleich bei der Bestellung angeben?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_YYPwDb": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Aus finanzrechtlichen Gründen ist es erforderlich, dass Freiexemplare bei der Bestellung verbindlich bekannt gegeben werden (im Feld „Freiexemplare“). Dadurch können sowohl die bestellenden Lehrpersonen als auch die Schule und das Jugendrotkreuz jederzeit nachweisen, dass die eingesammelten Elterngelder widmungsgemäß verwendet werden.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
