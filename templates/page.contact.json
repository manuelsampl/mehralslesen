                  "blocks": {
                    "text_9aYhQH": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Die Abos werden pro Schuljahr abgeschlossen und müssen somit<br/>nicht gekündigt werden. Eine Bestellung fürs neue Schuljahr ist ab Mitte April<br/>möglich.</p>",
