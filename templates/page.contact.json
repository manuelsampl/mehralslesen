                  "blocks": {
                    "text_7VrFHA": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Leider bieten wir keine Rückerstattungen an. Bitte beachten Sie, dass nach erfolgter Bestellung und Rechnungslegung kein nachträglicher Abzug von Freiexemplaren möglich ist. </p>",
