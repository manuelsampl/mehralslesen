                    "corner_radius": 0,
                    "padding-block-start": 0,
                    "padding-block-end": 0,
                    "padding-inline-start": 0,
                    "padding-inline-end": 0
                  },
                  "blocks": {}
                }
              },
              "block_order": [
                "text_CkDW6n"
              ]
            },
            "accordion_row_7HpVg3": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Kann ich als Privatperson die Schuleinschreibungshefte bestellen?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_Q3bkY7": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Wir bieten Schuleinschreibungshefte nur<br/>für Volksschuldirektor:innen, die das Heft an Eltern bei der Schuleinschreibung<br/>weitergeben, an.</p><p>Besteller:innen, die das Abo an eine<br/>Privatadresse schicken lassen möchten, bieten wir „Hallo Schule!“ als Privatabo<br/>an. Die erste Ausgabe beinhaltet ein Extraheft, das bei den ersten Schritten<br/>zum Lesen begleitet und beim spielerischen Üben der Vorläuferfertigkeiten hilft.</p>",
                    "width": "100%",
                    "max_width": "normal",
