              "blocks": {
                "accordion_row_pWt9iy": {
                  "type": "_accordion-row",
                  "name": "t:names.accordion_row",
                  "settings": {
                    "heading": "Was bedeutet: Die Jugendrotkreuz-Zeitschriften sind gemeinnützig?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_U7cBjQ": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Unser Zeitschriften-Angebot ist zu 100 % gemeinnützig. Das bedeutet, dass der Reinerlös aus dem Verkauf der Abos wiederum in Angebote des Jugendrotkreuzes für Kinder und Jugendliche fließt. So profitieren Schulen von weiteren, oft kostenfreien Angeboten wie zum Beispiel Schwimmabzeichen, Erste-Hilfe-Programme oder Angebote zur Gesundheitsförderung.</p>",
                        "width": "100%",
