                  "blocks": {
                    "text_9aYhQH": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Die Abos werden pro Schuljahr abgeschlossen und müssen somit nicht gekündigt werden. Eine Bestellung fürs neue Schuljahr ist ab Mitte April möglich. </p>",
