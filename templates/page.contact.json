                  "blocks": {
                    "text_h7Wcct": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Bei Bestellung bis September muss die Rechnung bis <strong>Ende<br/>Oktober</strong> bezahlt werden. Bei späteren Bestellungen haben Sie 30 Tage Zeit für die Bezahlung.</p>",
