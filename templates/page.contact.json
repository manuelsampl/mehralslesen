                  "blocks": {
                    "text_hNLyUC": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Antworten Sie einfach auf Ihre Bestellbestätigung, senden Sie<br/>uns ein E-Mail oder rufen uns an. Allfällige zusätzlich benötigte Exemplare liefern wir nach. <strong>Eine weitere Bestellung ist nicht erforderlich.</strong></p>",
