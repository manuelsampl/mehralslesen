                "accordion_row_YRfarq": {
                  "type": "_accordion-row",
                  "settings": {
                    "heading": "Kann ich als Privatperson die Schüler:innenzeitschriften bestellen?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_QyJKNz": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Wir<br/>bieten Privatbesteller:innen, die das Abo an eine Privatadresse schicken lassen<br/>möchten, ein eigenes Privatabo an. Auch dieses beinhaltet alle<br/>Online-Materialien. Wir<br/>bitten um Verständnis, dass Privatabos – in Abhängigkeit von erhöhtem<br/>Versandkostenaufwand – einen um € 12,– höheren Abopreis haben. </p><p>Das Privatabo ist nur als<br/>Jahresabo erhältlich. Wir senden selbstverständliche alle bereits erschienen<br/>Ausgaben nach Zahlungseingang nach.</p>",
                        "width": "100%",
