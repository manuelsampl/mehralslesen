                    "text_U69nV4": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Bis 20. September können Bestellungen über unser Aboservice ganz flexibel angepasst oder auch storniert werden. </p>",
                        "width": "100%",
                        "max_width": "normal",
