            "accordion_row_ArtiQX": {
              "type": "_accordion-row",
              "name": "t:names.accordion_row",
              "settings": {
                "heading": "Muss ich das Abo am Ende des Schuljahrs kündigen oderläuft es automatisch aus?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_iWMdAc": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Die Abos werden pro Schuljahr abgeschlossen und müssen somit<br/>nicht gekündigt werden. Eine Bestellung fürs neue Schuljahr ist ab Mitte April<br/>möglich.</p>",
                    "width": "100%",
