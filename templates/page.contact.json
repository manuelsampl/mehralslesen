                  ]
                },
                "accordion_row_mE6FAf": {
                  "type": "_accordion-row",
                  "name": "t:names.accordion_row",
                  "settings": {
                    "heading": "Gibt es Freiexemplare?",
                    "open_by_default": false,
                    "icon": "none",
                    "width": 20
                  },
                  "blocks": {
                    "text_Gxyxbb": {
                      "type": "text",
                      "settings": {
                        "text": "<p>Leseförderung soll für ALLE Schüler:innen zugänglich sein. Deswegen können bis zu<strong> </strong>10 %<strong> </strong>der Bestellmenge als Schüler:innenfreiexemplare für Kinder und Jugendliche aus Haushalten mit geringerem Einkommen in Anspruch genommen werden. Zusätzlich stehen Ihnen bis zu 10 % Ihrer Bestellmenge als Lehrer:innenexemplare zu.</p>",
                        "width": "100%",
                        "max_width": "normal",
                        "alignment": "left",
                        "type_preset": "rte",
                        "font": "var(--font-body--family)",
                        "font_size": "1rem",
